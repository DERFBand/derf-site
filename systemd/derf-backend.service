[Unit]
Description=D.E.R.F. FastAPI backend
After=network.target

[Service]
User=deploy
Group=deploy
WorkingDirectory=/srv/derf-backend
ExecStart=/srv/derf-backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 4
Restart=always
RestartSec=5
EnvironmentFile=/srv/derf-backend/.env

[Install]
WantedBy=multi-user.target